PORT=3000
JWT_SECRET=change_me_dev_secret_at_least_32_chars_long

DATABASE_URL="file:./dev.db"

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Если не заполнить — автоматически используется Ethereal (тестовые письма)
# Посмотреть тестовые письма: https://ethereal.email
#
# Для реальных писем (Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password   # Нужен App Password, не обычный пароль
# SMTP_FROM="Funding Aggregator <your@gmail.com>"
#
# Для Yandex:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_USER=your@yandex.ru
# SMTP_PASS=your_password
#
# Для mail.ru:
# SMTP_HOST=smtp.mail.ru
# SMTP_PORT=465
# SMTP_USER=your@mail.ru
# SMTP_PASS=your_password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Funding Aggregator <noreply@funding-aggregator.demo>"
