{
  "name": "funding-aggregator-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./src/server.js",
    "start": "node ./src/server.js",
    "prisma": "prisma",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "node ./prisma/seed.js",
    "scrape": "node -e \"import('./src/scraper.js').then(m=>m.runScraper()).then(r=>{ console.log(r); process.exit(0); }).catch(e=>{ console.error(e); process.exit(1); })\"",
    "notify": "node -e \"import('./src/notifier.js').then(m=>m.sendDeadlineReminders()).then(r=>{ console.log(r); process.exit(0); }).catch(e=>{ console.error(e); process.exit(1); })\"",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=integration --runInBand",
    "test:all": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "extensionsToTreatAsEsm": [".js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageDirectory": "test-results/coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^6.8.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    
  }
}
